# ── PartyPix configuration ──
# Copy to ".env" and fill in. All values are optional except in production
# you should set PUBLIC_URL so QR codes resolve to the right host.

# Public base URL of your deployment (no trailing slash).
PUBLIC_URL=https://your-domain.com

# Server port (App Platform sets this automatically).
PORT=3000

# Where SQLite + local uploads live. Keep on a persistent volume.
DATA_DIR=/data

# ── Storage backend ──
# "local" (default, disk) or "spaces" (DigitalOcean Spaces / S3-compatible).
STORAGE_DRIVER=local

# Required only when STORAGE_DRIVER=spaces:
# SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
# SPACES_REGION=nyc3
# SPACES_BUCKET=my-partypix-bucket
# SPACES_KEY=your-spaces-access-key
# SPACES_SECRET=your-spaces-secret
# SPACES_CDN_BASE=https://my-partypix-bucket.nyc3.cdn.digitaloceanspaces.com

# ── Limits / plan guardrails ──
MAX_FILE_BYTES=26214400
MAX_FILES_PER_REQUEST=12
FREE_PLAN_PHOTO_CAP=300
PRO_PLAN_PHOTO_CAP=5000

# Comma-separated allowed CORS origins (leave blank for same-origin only).
CORS_ORIGINS=
